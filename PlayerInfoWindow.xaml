<Window x:Class="ApocMinimal.PlayerInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация об игроке" Height="640" Width="700"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Consolas" FontSize="12"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style x:Key="TableCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel>

            <!-- HEADER: Name + Faction + Day -->
            <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="NameLabel" FontSize="16" FontWeight="Bold"
                                   Foreground="#f0f6fc"/>
                        <TextBlock x:Name="FactionLabel" FontSize="13" Margin="0,2,0,0"/>
                        <TextBlock x:Name="FactionDesc" FontSize="11" Foreground="#8b949e"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBlock x:Name="DayLabel" Foreground="#8b949e" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="TerminalLabel" Foreground="#58a6ff"
                                   HorizontalAlignment="Right" Margin="0,3,0,0"/>
                        <TextBlock x:Name="FollowersLabel" Foreground="#56d364"
                                   HorizontalAlignment="Right" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TWO COLUMN SECTION -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Faction Coefficients -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="КОЭФФИЦИЕНТЫ ФРАКЦИИ" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                        <StackPanel x:Name="CoeffPanel" Margin="6,4"/>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Follower Limits -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ЛИМИТЫ ПОСЛЕДОВАТЕЛЕЙ" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                        <StackPanel Margin="6,4">
                            <!-- Header row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ур." Style="{StaticResource TableHeader}"/>
                                <TextBlock Grid.Column="1" Text="Есть" Style="{StaticResource TableHeader}"/>
                                <TextBlock Grid.Column="2" Text="Лимит" Style="{StaticResource TableHeader}"/>
                                <TextBlock Grid.Column="3" Text="ОР/день" Style="{StaticResource TableHeader}"/>
                            </Grid>
                            <StackPanel x:Name="FollowerLimitsPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Close -->
            <Button Content="Закрыть" Height="30" Margin="0,12,0,0"
                    Background="#21262d" Foreground="#c9d1d9"
                    BorderBrush="#30363d" BorderThickness="1"
                    Cursor="Hand" Click="CloseBtn_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>
