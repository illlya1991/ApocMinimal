<Window x:Class="ApocMinimal.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карта мира" Height="620" Width="700"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Consolas" FontSize="12"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,8">
            <TextBlock Text="КАРТА МИРА" Foreground="#7dd3fc"
                       FontSize="13" FontWeight="Bold"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel x:Name="MapPanel"/>
        </ScrollViewer>
    </Grid>
</Window>
