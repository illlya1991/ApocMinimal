<Window x:Class="ApocMinimal.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симуляция Апокалипсиса"
        Height="520" Width="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d0d1a">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">

            <TextBlock Text="ЗЕМЛЯ ПОСЛЕ КОНЦА. ТЫ ИЛИ ТЕБЯ?"
                       Foreground="#e0e0e0"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

            <TextBlock Text="Управляй выжившими. Развивай Терминал."
                       Foreground="#666"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Faction selection — only for new game -->
            <StackPanel x:Name="FactionSection" Visibility="Collapsed">
                <TextBlock Text="ВЫБЕРИ ФРАКЦИЮ (только для новой игры)"
                           Foreground="#6b7280"
                           FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="FactionCombo"
                          Height="34" FontSize="13" FontWeight="Bold"
                          Background="#161b22"
                          Margin="0,0,0,6"/>
                <TextBlock x:Name="FactionDescText"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>
            </StackPanel>

            <Button x:Name="NewGameButton"
                    Content="Новая игра"
                    Height="42" FontSize="14"
                    Background="#4a90d9" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,0,10"
                    Click="NewGame_Click"/>

            <Button x:Name="ContinueButton"
                    Content="Загрузить игру"
                    Height="42" FontSize="14"
                    Background="#2a6040" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,0,20"
                    Click="Continue_Click"/>

            <TextBlock x:Name="SaveInfoText"
                       Foreground="#555"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>

</Window>
