<Window x:Class="ApocMinimal.SaveSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вибір збереження"
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d0d1a">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">

            <TextBlock x:Name="TitleText"
                       Text="Вибір збереження"
                       Foreground="#e0e0e0"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="DescriptionText"
                       Text="Оберіть збереження для продовження:"
                       Foreground="#666"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SavesPanel">
                    <!-- Кнопки збережень будуть додані програмно -->
                </StackPanel>
            </ScrollViewer>

            <Button x:Name="CancelButton"
                    Content="Скасувати"
                    Height="35" FontSize="13"
                    Background="#333" Foreground="#ccc"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,20,0,0"
                    Click="Cancel_Click"/>

        </StackPanel>
    </Grid>

</Window>