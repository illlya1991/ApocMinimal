<Window x:Class="ApocMinimal.SaveSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сохранения"
        Height="560" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0d0d1a" CornerRadius="8" BorderBrush="#1e2a3a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#0a0f1e" CornerRadius="8,8,0,0" Padding="20,16">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="Новая игра"
                               Foreground="#e0e0e0"
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Background="Transparent"
                            Foreground="#666"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock x:Name="DescriptionText"
                           Foreground="#8b949e"
                           FontSize="12"
                           Margin="0,0,0,16"/>

                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SavesPanel"/>
                </ScrollViewer>

                <!-- Панель подтверждения перезаписи (скрыта по умолчанию) -->
                <Border x:Name="ConfirmPanel"
                        Visibility="Collapsed"
                        Background="#1a1a2e" CornerRadius="4"
                        BorderBrush="#f87171" BorderThickness="1"
                        Padding="14,10" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock x:Name="ConfirmText"
                                   Foreground="#f87171"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ConfirmYesBtn"
                                    Content="Перезаписать"
                                    Width="110" Height="30" FontSize="12"
                                    Background="#c0392b" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,8,0"
                                    Click="ConfirmYes_Click"/>
                            <Button Content="Отмена"
                                    Width="80" Height="30" FontSize="12"
                                    Background="#1e2a3a" Foreground="#8b949e"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="ConfirmNo_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Панель подтверждения удаления (скрыта по умолчанию) -->
                <Border x:Name="DeleteConfirmPanel"
                        Visibility="Collapsed"
                        Background="#1a1a2e" CornerRadius="4"
                        BorderBrush="#f87171" BorderThickness="1"
                        Padding="14,10" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock x:Name="DeleteConfirmText"
                                   Foreground="#f87171"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DeleteYesBtn"
                                    Content="Удалить"
                                    Width="80" Height="30" FontSize="12"
                                    Background="#c0392b" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,8,0"
                                    Click="DeleteYes_Click"/>
                            <Button Content="Отмена"
                                    Width="80" Height="30" FontSize="12"
                                    Background="#1e2a3a" Foreground="#8b949e"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="DeleteNo_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Кнопка Отмена -->
            <Border Grid.Row="2" Background="#0a0f1e" CornerRadius="0,0,8,8" Padding="20,12">
                <Button Content="Отмена"
                        Height="34" FontSize="13"
                        Background="#1e2a3a" Foreground="#8b949e"
                        BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
