<Window x:Class="ApocMinimal.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ApocMinimal.Controls"
        Title="Apocalypse Simulation" Height="780" Width="1300"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Consolas" FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- TOP HEADER -->
        <Border DockPanel.Dock="Top" 
                BorderBrush="#30363d" 
                BorderThickness="0,0,0,1" 
                Padding="12,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#161b22" Offset="0"/>
                    <GradientStop Color="#1a1a2e" Offset="0.5"/>
                    <GradientStop Color="#161b22" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="PlayerNameLabel" Text="Игрок" FontSize="15"
                               Foreground="#f0f6fc" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PlayerFactionLabel" Text="  |  Землянин" FontSize="15"
                                Foreground="#f0f6fc" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DayLabel" Text="  |  День 1"
                               Foreground="#8b949e" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock x:Name="FaithLabel" Text="  0 ОР"
                               Foreground="#d29922" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AltarLabel" Text="  Терминал: ур.1"
                               Foreground="#58a6ff" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock x:Name="ActionsLabel" Text="  Действий: 0/10"
                               Foreground="#56d364" VerticalAlignment="Center" Margin="8,0"/>

                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PlayerInfoBtn" Content="👤 Игрок"
                            Style="{StaticResource ActionBtn}"
                            Background="#1a2a3a" Foreground="#a5d6ff"
                            Width="90" Margin="0,0,8,0" Click="PlayerInfoBtn_Click"/>
                    <Button x:Name="QuestsBtn" Content="📜 КВЕСТЫ"
                            Style="{StaticResource ActionBtn}"
                            Background="#1a3a2a" Foreground="#56d364"
                            Width="110" Margin="0,0,8,0" Click="QuestsBtn_Click"/>
                    <Button x:Name="FullscreenInfoBtn" Content="📊 ПОЛНЫЙ ОБЗОР"
                            Style="{StaticResource ActionBtn}"
                            Background="#2d1b69" Foreground="#d2a8ff"
                            Width="130" Click="FullscreenInfo_Click"/>
                    <Button x:Name="SettingsBtn" Content="⚙"
                            Style="{StaticResource ActionBtn}"
                            Background="#21262d" Foreground="#8b949e"
                            Width="36" Margin="8,0,0,0" FontSize="15"
                            Click="SettingsBtn_Click"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="EndDayBtn" Content="КОНЕЦ ДНЯ"
                        Style="{StaticResource ActionBtn}"
                        Background="#1f4e8c" Foreground="#a5d6ff"
                        Width="130" Margin="8,0,0,0" Click="EndDayBtn_Click"/>
            </Grid>
        </Border>

        <!-- LEFT PANEL: NPC LIST -->
        <local:NpcListControl x:Name="NpcListControl" DockPanel.Dock="Left" Width="260"/>

        <!-- CENTER + RIGHT: Grid — sidebar не перекрывает панель действий -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>
            <local:LogControl           x:Name="LogControl"           Grid.Column="0"/>
            <local:NpcSidebarControl    x:Name="NpcSidebarControl"    Grid.Column="1"/>
            <local:PlayerActionsControl x:Name="PlayerActionsControl" Grid.Column="2"/>
        </Grid>
    </DockPanel>

    <!-- Settings Overlay -->
    <Border x:Name="SettingsOverlay"
            Visibility="Collapsed"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,44,8,0"
            Width="260"
            Background="#0d0d1a"
            BorderBrush="#1e2a3a" BorderThickness="1"
            CornerRadius="6"
            Panel.ZIndex="100">
        <StackPanel Margin="12,10">
            <Button Content="Вернуться в меню"
                    Height="34" FontSize="12"
                    Background="#161b22" Foreground="#c9d1d9"
                    BorderBrush="#30363d" BorderThickness="1"
                    Cursor="Hand" Margin="0,0,0,6"
                    Click="MenuNoSave_Click"/>
            <Button Content="Сохранить и выйти в меню"
                    Height="34" FontSize="12"
                    Background="#1a3a2a" Foreground="#56d364"
                    BorderBrush="#2a6040" BorderThickness="1"
                    Cursor="Hand" Margin="0,0,0,6"
                    Click="MenuSave_Click"/>
            <Button Content="Выйти из игры"
                    Height="34" FontSize="12"
                    Background="#1e1010" Foreground="#f87171"
                    BorderBrush="#4a1010" BorderThickness="1"
                    Cursor="Hand"
                    Click="ExitGame_Click"/>
        </StackPanel>
    </Border>

    </Grid>
</Window>
