<Window x:Class="ApocMinimal.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ApocMinimal.Controls"
        Title="Apocalypse Simulation" Height="780" Width="1300"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Consolas" FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- TOP HEADER -->
        <Border DockPanel.Dock="Top" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="APOCALYPSE SIMULATION" FontSize="15"
                               Foreground="#f0f6fc" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DayLabel" Text="  |  День 1"
                               Foreground="#8b949e" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock x:Name="FaithLabel" Text="  0 веры"
                               Foreground="#d29922" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AltarLabel" Text="  Алтарь: ур.1"
                               Foreground="#58a6ff" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock x:Name="ActionsLabel" Text="  Действий: 0/10"
                               Foreground="#56d364" VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="FullscreenInfoBtn" Content="📊 ПОЛНЫЙ ОБЗОР" 
                        Style="{StaticResource ActionBtn}"
                        Background="#2d1b69" Foreground="#d2a8ff"
                        Width="130" Click="FullscreenInfo_Click"/>
                <Button Grid.Column="2" x:Name="EndDayBtn" Content="КОНЕЦ ДНЯ"
                        Style="{StaticResource ActionBtn}"
                        Background="#1f4e8c" Foreground="#a5d6ff"
                        Width="130" Margin="8,0,0,0" Click="EndDayBtn_Click"/>
            </Grid>
        </Border>

        <!-- LEFT PANEL: NPC LIST -->
        <local:NpcListControl x:Name="NpcListControl" DockPanel.Dock="Left" Width="260"/>

        <!-- RIGHT SIDEBAR: NPC INFO (выезжает справа от лога) -->
        <local:NpcSidebarControl x:Name="NpcSidebarControl" DockPanel.Dock="Right" Width="350"/>

        <!-- CENTER: LOG -->
        <DockPanel>
            <local:LogControl x:Name="LogControl" />
        </DockPanel>

        <!-- RIGHT PANEL: PLAYER ACTIONS (вкладки) -->ф
        <local:PlayerActionsControl x:Name="PlayerActionsControl" DockPanel.Dock="Right" Width="310"/>
    </DockPanel>
</Window>