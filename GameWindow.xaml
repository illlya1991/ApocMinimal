<Window x:Class="ApocMinimal.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симуляция Апокалипсиса"
        Height="780" Width="1200"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d1a">

    <Window.Resources>
        <!-- Шаблон строки лога -->
        <DataTemplate x:Key="LogTemplate">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding Color}"
                       FontFamily="Consolas"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Padding="2,1"/>
        </DataTemplate>

        <!-- Пункты выпадающего списка: чёрный текст на белом фоне -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding"    Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#cce0f5"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Сам ComboBox: светлый фон, чёрный текст (включая выбранный элемент) -->
        <Style x:Key="LightCombo" TargetType="ComboBox">
            <Setter Property="Background"  Value="#ffffff"/>
            <Setter Property="Foreground"  Value="#111111"/>
            <Setter Property="BorderBrush" Value="#2a3a60"/>
            <Setter Property="Height"      Value="28"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="#4a90d9"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="DayBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Background"      Value="#7c3aed"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">

        <!-- ===== ШАПКА ===== -->
        <Border DockPanel.Dock="Top"
                Background="#16213e" CornerRadius="4"
                Padding="12,7" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HeaderText"
                           Grid.Column="0"
                           Foreground="#aad4f5" FontSize="13"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⏭  Завершить день"
                        Style="{StaticResource DayBtn}"
                        Width="165"
                        Click="EndDay_Click"/>
            </Grid>
        </Border>

        <!-- ===== ЛЕВАЯ ПАНЕЛЬ: НПС ===== -->
        <Border DockPanel.Dock="Left"
                Width="240"
                Background="#111827"
                CornerRadius="4"
                Margin="0,0,8,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="  ПЕРСОНАЖИ"
                           Foreground="#60a5fa"
                           FontSize="12" FontWeight="Bold"
                           Padding="8,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NpcCardsPanel"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== ПРАВАЯ ПАНЕЛЬ: ДЕЙСТВИЯ + АЛТАРЬ ===== -->
        <Border DockPanel.Dock="Right"
                Width="280"
                Background="#111827"
                CornerRadius="4"
                Margin="8,0,0,0">
            <DockPanel>

                <!-- Алтарь внизу -->
                <Border DockPanel.Dock="Bottom"
                        Background="#1a1a0a"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="6,0,6,6">
                    <StackPanel>
                        <TextBlock Text="✦  АЛТАРЬ"
                                   Foreground="#facc15"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="AltarInfoText"
                                   Foreground="#d4c26a"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="UpgradeAltarBtn"
                                Content="Улучшить алтарь"
                                Height="28" FontSize="12"
                                Background="#92400e"
                                Foreground="#facc15"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="UpgradeAltar_Click"/>
                    </StackPanel>
                </Border>

                <!-- Панель действий -->
                <Border Background="#16213e"
                        CornerRadius="4"
                        Padding="10,10"
                        Margin="6,6,6,4">
                    <StackPanel>
                        <TextBlock Text="ДЕЙСТВИЕ ИГРОКА"
                                   Foreground="#60a5fa"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Действие:" Foreground="#aaa" FontSize="12" Margin="0,0,0,3"/>
                        <ComboBox x:Name="ActionCombo"
                                  Style="{StaticResource LightCombo}"
                                  Margin="0,0,0,8"
                                  SelectionChanged="ActionCombo_SelectionChanged"/>

                        <TextBlock x:Name="NpcLabel" Text="Персонаж:" Foreground="#aaa"
                                   FontSize="12" Margin="0,0,0,3" Visibility="Collapsed"/>
                        <ComboBox x:Name="NpcCombo"
                                  Style="{StaticResource LightCombo}"
                                  Margin="0,0,0,8"
                                  Visibility="Collapsed"/>

                        <!-- Передать ресурс -->
                        <TextBlock x:Name="ResLabel" Text="Ресурс:" Foreground="#aaa"
                                   FontSize="12" Margin="0,0,0,3" Visibility="Collapsed"/>
                        <ComboBox x:Name="ResourceCombo"
                                  Style="{StaticResource LightCombo}"
                                  Margin="0,0,0,6"
                                  Visibility="Collapsed"/>

                        <Grid x:Name="AmountRow" Visibility="Collapsed" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Кол-во: " Foreground="#aaa"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="AmountBox"
                                     Grid.Column="1"
                                     Background="White" Foreground="#111"
                                     BorderBrush="#2a3a60" Height="28"
                                     FontSize="13" VerticalContentAlignment="Center"
                                     Padding="4,0" Text="1"/>
                        </Grid>

                        <!-- Задание -->
                        <TextBlock x:Name="TaskLabel" Text="Задание:" Foreground="#aaa"
                                   FontSize="12" Margin="0,0,0,3" Visibility="Collapsed"/>
                        <ComboBox x:Name="TaskCombo"
                                  Style="{StaticResource LightCombo}"
                                  Margin="0,0,0,8"
                                  Visibility="Collapsed"/>

                        <Button x:Name="ActionButton"
                                Style="{StaticResource ActionBtn}"
                                Visibility="Collapsed"
                                Click="ActionButton_Click"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ===== ЦЕНТР: ЛОГ СОБЫТИЙ ===== -->
        <Border Background="#0a0f1e" CornerRadius="4">
            <ListBox x:Name="EventLog"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="6"
                     ItemTemplate="{StaticResource LogTemplate}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     HorizontalContentAlignment="Stretch"/>
        </Border>

    </DockPanel>
</Window>
