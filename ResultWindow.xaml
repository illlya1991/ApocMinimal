<Window x:Class="ApocMinimal.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результат"
        Height="420" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d0d1a">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">

            <TextBlock x:Name="TitleText"
                       FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="SubtitleText"
                       FontSize="13" Foreground="#8b949e"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <Border Background="#161b22" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                <TextBlock x:Name="ProgressText"
                           FontFamily="Consolas" FontSize="13"
                           Foreground="#c9d1d9" TextWrapping="Wrap"
                           LineHeight="22"/>
            </Border>

            <Button x:Name="CloseBtn"
                    Content="В ГЛАВНОЕ МЕНЮ"
                    Click="CloseBtn_Click"
                    FontSize="13" FontWeight="Bold"
                    Foreground="White"
                    Background="#21262d"
                    BorderBrush="#30363d"
                    Padding="20,10"
                    HorizontalAlignment="Center"
                    Cursor="Hand"/>

        </StackPanel>
    </Grid>
</Window>
