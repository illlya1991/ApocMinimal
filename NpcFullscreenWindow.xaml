<Window x:Class="ApocMinimal.NpcFullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Полный обзор NPC"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Foreground="#c9d1d9"
        FontFamily="Consolas"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="ModeBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1f4e8c"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4,4,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0d1117"/>
                    <Setter Property="Foreground" Value="#60a5fa"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LightCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Height" Value="26"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Верхняя панель -->
        <Border DockPanel.Dock="Top" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel>
                <!-- Заголовок и кнопка закрытия -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText" Text="ПОЛНЫЙ ОБЗОР NPC" FontSize="18" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕" Width="30" Height="30" Background="#21262d" Foreground="#f87171" 
                            BorderBrush="#30363d" BorderThickness="1" Click="Close_Click" Cursor="Hand"/>
                </Grid>

                <!-- Выбор режима -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="TabView" Content="📖 ПРОСМОТР" Style="{StaticResource TabBtn}" IsChecked="True" GroupName="Mode"/>
                    <RadioButton x:Name="TabCompare" Content="🔄 СРАВНЕНИЕ" Style="{StaticResource TabBtn}" GroupName="Mode"/>
                </StackPanel>

                <!-- Панель выбора NPC (для режима просмотра) -->
                <StackPanel x:Name="ViewSelectorPanel" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Выберите NPC:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="NpcSelector" Width="200" Style="{StaticResource LightCombo}" SelectionChanged="NpcSelector_SelectionChanged"/>
                </StackPanel>

                <!-- Панель выбора NPC для сравнения -->
                <Grid x:Name="CompareSelectorPanel" Visibility="Collapsed" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NPC 1:" Foreground="#8b949e" Margin="0,0,0,5"/>
                        <ComboBox x:Name="NpcSelectorLeft" Style="{StaticResource LightCombo}" SelectionChanged="CompareSelector_SelectionChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="VS" Foreground="#60a5fa" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NPC 2:" Foreground="#8b949e" Margin="0,0,0,5"/>
                        <ComboBox x:Name="NpcSelectorRight" Style="{StaticResource LightCombo}" SelectionChanged="CompareSelector_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопки режимов отображения -->
                <WrapPanel x:Name="ModeButtons" Margin="0,10,0,0">
                    <RadioButton x:Name="ModeFull" Content="📋 Все" Style="{StaticResource ModeBtn}" GroupName="DisplayMode" IsChecked="True" Tag="full" Checked="DisplayMode_Changed"/>
                    <RadioButton x:Name="ModeDetailed" Content="📊 Детально" Style="{StaticResource ModeBtn}" GroupName="DisplayMode" Tag="detailed" Checked="DisplayMode_Changed"/>
                    <RadioButton x:Name="ModeCompact" Content="📄 Сжато" Style="{StaticResource ModeBtn}" GroupName="DisplayMode" Tag="compact" Checked="DisplayMode_Changed"/>
                    <RadioButton x:Name="ModeCombat" Content="⚔ Боевое" Style="{StaticResource ModeBtn}" GroupName="DisplayMode" Tag="combat" Checked="DisplayMode_Changed"/>
                    <RadioButton x:Name="ModeSocial" Content="💬 Социальное" Style="{StaticResource ModeBtn}" GroupName="DisplayMode" Tag="social" Checked="DisplayMode_Changed"/>
                </WrapPanel>

                <!-- Опции сравнения -->
                <StackPanel x:Name="CompareOptions" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                    <CheckBox x:Name="HighlightSame" Content="Подсветить одинаковое" Foreground="#c9d1d9" Margin="0,0,15,0" Checked="CompareOption_Changed"/>
                    <CheckBox x:Name="HighlightDifferent" Content="Подсветить разное" Foreground="#c9d1d9" Checked="CompareOption_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid x:Name="MainContent">
                <!-- Режим просмотра (один NPC) -->
                <ScrollViewer x:Name="ViewContent" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ViewInfoPanel" Margin="20"/>
                </ScrollViewer>

                <!-- Режим сравнения (два NPC) -->
                <Grid x:Name="CompareContent" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CompareLeftPanel" Margin="20"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CompareRightPanel" Margin="20"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>