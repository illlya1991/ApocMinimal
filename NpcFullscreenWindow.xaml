<Window x:Class="ApocMinimal.NpcFullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ApocMinimal.Controls"
        Title="Полный обзор NPC"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Foreground="#c9d1d9"
        FontFamily="Consolas"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="TabButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4,4,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0d1117"/>
                    <Setter Property="Foreground" Value="#60a5fa"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LightCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Height" Value="26"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Верхняя панель -->
        <Border DockPanel.Dock="Top" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ПОЛНЫЙ ОБЗОР NPC" FontSize="18" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕" Width="30" Height="30" Background="#21262d" Foreground="#f87171" 
                            BorderBrush="#30363d" BorderThickness="1" Click="Close_Click" Cursor="Hand"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ToggleButton x:Name="TabView" Content="📖 ПРОСМОТР" Style="{StaticResource TabButton}" IsChecked="True"/>
                    <ToggleButton x:Name="TabCompare" Content="🔄 СРАВНЕНИЕ" Style="{StaticResource TabButton}"/>
                </StackPanel>

                <!-- Панель выбора NPC (режим просмотра) -->
                <StackPanel x:Name="ViewSelectorPanel" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Выберите NPC:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="NpcSelector" Width="200" Style="{StaticResource LightCombo}"/>
                </StackPanel>

                <!-- Панель выбора NPC для сравнения -->
                <Grid x:Name="CompareSelectorPanel" Visibility="Collapsed" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NPC 1:" Foreground="#8b949e" Margin="0,0,0,5"/>
                        <ComboBox x:Name="NpcSelectorLeft" Style="{StaticResource LightCombo}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="VS" Foreground="#60a5fa" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NPC 2:" Foreground="#8b949e" Margin="0,0,0,5"/>
                        <ComboBox x:Name="NpcSelectorRight" Style="{StaticResource LightCombo}"/>
                    </StackPanel>
                </Grid>

                <!-- Опции сравнения -->
                <StackPanel x:Name="CompareOptions" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                    <CheckBox x:Name="HighlightSame" Content="Подсветить одинаковое" Foreground="#c9d1d9" Margin="0,0,15,0"/>
                    <CheckBox x:Name="HighlightDifferent" Content="Подсветить разное" Foreground="#c9d1d9"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <Grid x:Name="MainContent">
            <!-- Режим просмотра (один NPC) -->
            <local:NpcInfoControl x:Name="SingleNpcInfo" Margin="20"/>

            <!-- Режим сравнения (два NPC) -->
            <Grid x:Name="CompareContent" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                    <local:NpcInfoControl x:Name="LeftNpcInfo" Margin="20"/>
                </Border>
                <Border Grid.Column="1">
                    <local:NpcInfoControl x:Name="RightNpcInfo" Margin="20"/>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>