<Window x:Class="ApocMinimal.NewGameSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая игра"
        Height="500" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d0d1a">

    <Grid Margin="32">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="НАСТРОЙКА НОВОГО МИРА"
                       Foreground="#8b949e"
                       FontSize="11" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Player name -->
            <TextBlock Text="Имя игрока"
                       Foreground="#6b7280"
                       FontSize="11"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="NameBox"
                     Height="36" FontSize="14"
                     Background="#161b22" Foreground="#e0e0e0"
                     BorderBrush="#30363d" BorderThickness="1"
                     Padding="8,0"
                     CaretBrush="White"
                     VerticalContentAlignment="Center"
                     MaxLength="24"
                     Margin="0,0,0,24"/>

            <!-- Faction -->
            <TextBlock Text="Фракция"
                       Foreground="#6b7280"
                       FontSize="11"
                       Margin="0,0,0,6"/>
            <ListBox x:Name="FactionList"
                     Background="#161b22"
                     BorderBrush="#30363d"
                     BorderThickness="1"
                     SelectionChanged="FactionList_SelectionChanged"
                     Margin="0,0,0,10"/>

            <Border x:Name="DescBorder"
                    Background="#161b22" CornerRadius="4"
                    Padding="10,8" Margin="0,0,0,24"
                    MinHeight="42">
                <TextBlock x:Name="FactionDescText"
                           FontSize="11" TextWrapping="Wrap"
                           Foreground="#8b949e"/>
            </Border>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="ОТМЕНА"
                        Click="Cancel_Click"
                        Height="36" FontSize="12"
                        Foreground="#8b949e" Background="#21262d"
                        BorderBrush="#30363d" Cursor="Hand"/>
                <Button Grid.Column="2"
                        x:Name="ConfirmBtn"
                        Content="НАЧАТЬ ИГРУ"
                        Click="Confirm_Click"
                        Height="36" FontSize="12" FontWeight="Bold"
                        Foreground="White" Background="#4a90d9"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>

        </StackPanel>
    </Grid>
</Window>
