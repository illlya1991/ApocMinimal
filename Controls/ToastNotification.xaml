<UserControl x:Class="ApocMinimal.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Height="60">
    <Border Background="#1a1a2e" 
            BorderBrush="#60a5fa" 
            BorderThickness="1"
            CornerRadius="6"
            Margin="5">
        <Grid Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="IconText" Grid.Column="0" Text="ℹ" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="MessageText" Grid.Column="1" Text="" Foreground="#c9d1d9" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" FontFamily="Consolas"/>
            <Button x:Name="CloseBtn" Grid.Column="2" Content="✕" Width="20" Height="20" 
                    Background="Transparent" Foreground="#8b949e" BorderThickness="0"
                    Cursor="Hand" FontSize="10" Click="CloseBtn_Click"/>
        </Grid>
    </Border>
</UserControl>