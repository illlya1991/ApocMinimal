<UserControl x:Class="ApocMinimal.Controls.NpcListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="260">

    <UserControl.Resources>
        <Style x:Key="TabBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#58a6ff"/>
                    <Setter Property="BorderBrush" Value="#58a6ff"/>
                    <Setter Property="Background" Value="#0d1117"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#21262d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="PageButton" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                    <Setter Property="Foreground" Value="#c9d1d9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#0d1117" BorderBrush="#30363d" BorderThickness="0,0,1,0">
        <DockPanel>

            <!-- TABS -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                        Background="#161b22" Height="28">
                <ToggleButton x:Name="TabFollowers" Content="Последователи"
                              Style="{StaticResource TabBtn}" IsChecked="True"
                              Click="Tab_Click"/>
                <ToggleButton x:Name="TabTerritory" Content="На территории"
                              Style="{StaticResource TabBtn}"
                              Click="Tab_Click"/>
                <ToggleButton x:Name="TabNearby" Content="Рядом"
                              Style="{StaticResource TabBtn}"
                              Click="Tab_Click"/>
            </StackPanel>

            <!-- FILTERS (followers tab only) -->
            <Border DockPanel.Dock="Top" x:Name="FilterPanel"
                    Padding="8,4" Background="#0d1117"
                    BorderBrush="#30363d" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,3,0">
                        <TextBlock Text="Последователь" Foreground="#8b949e" FontSize="9" Margin="0,0,0,2"/>
                        <ComboBox x:Name="FilterFollower" Style="{StaticResource FilterCombo}"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="3,0,0,0">
                        <TextBlock Text="Пробуждение" Foreground="#8b949e" FontSize="9" Margin="0,0,0,2"/>
                        <ComboBox x:Name="FilterEvolution" Style="{StaticResource FilterCombo}"
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- COUNT HEADER -->
            <Border DockPanel.Dock="Top" Padding="8,4"
                    BorderBrush="#30363d" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock x:Name="TabCountLabel" Text="0 НПС"
                               Foreground="#8b949e" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FollowerCountLabel" Text=""
                               Foreground="#60a5fa" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- PAGINATION -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,6,0,6">
                <Button x:Name="PrevPageBtn" Content="◀" Style="{StaticResource PageButton}"
                        Click="PrevPage_Click" IsEnabled="False"/>
                <TextBlock x:Name="PageInfoLabel" Text="1"
                           Foreground="#8b949e" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0"/>
                <Button x:Name="NextPageBtn" Content="▶" Style="{StaticResource PageButton}"
                        Click="NextPage_Click"/>
            </StackPanel>

            <!-- NPC LIST -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel x:Name="NpcPanel"/>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
