<UserControl x:Class="ApocMinimal.Controls.NpcInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="350">

    <UserControl.Resources>
        <!-- Стиль для кнопок режимов -->
        <Style x:Key="ModeButton" TargetType="RadioButton">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                BorderThickness="1"
                                BorderBrush="#30363d">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1f4e8c"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#0d1117">
        <DockPanel>
            <!-- Заголовок -->
            <Border x:Name="HeaderBorder" DockPanel.Dock="Top" 
                    Background="#161b22" 
                    BorderBrush="#30363d" 
                    BorderThickness="0,0,0,1" 
                    Padding="10,6"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText" 
                               Text="ИНФОРМАЦИЯ О NPC" 
                               Foreground="#60a5fa" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" 
                            x:Name="CloseButton" 
                            Content="✕" 
                            Width="24" 
                            Height="24"
                            Background="#21262d" 
                            Foreground="#f87171" 
                            BorderBrush="#30363d" 
                            BorderThickness="1"
                            Click="CloseButton_Click" 
                            Cursor="Hand" 
                            ToolTip="Закрыть панель"/>
                </Grid>
            </Border>

            <!-- Кнопки режимов -->
            <Border DockPanel.Dock="Top" Padding="10,8" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                <WrapPanel x:Name="ModeButtonsPanel">
                    <RadioButton x:Name="ModeFull" Content="📋 Все" Style="{StaticResource ModeButton}" Tag="full" Checked="Mode_Checked"/>
                    <RadioButton x:Name="ModeDetailed" Content="📊 Детально" Style="{StaticResource ModeButton}" Tag="detailed" Checked="Mode_Checked"/>
                    <RadioButton x:Name="ModeCompact" Content="📄 Сжато" Style="{StaticResource ModeButton}" Tag="compact" Checked="Mode_Checked"/>
                    <RadioButton x:Name="ModeCombat" Content="⚔ Боевое" Style="{StaticResource ModeButton}" Tag="combat" Checked="Mode_Checked"/>
                    <RadioButton x:Name="ModeSocial" Content="💬 Социальное" Style="{StaticResource ModeButton}" Tag="social" Checked="Mode_Checked"/>
                </WrapPanel>
            </Border>

            <!-- Контент -->
            <ScrollViewer x:Name="ContentScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentPanel" Margin="10"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>