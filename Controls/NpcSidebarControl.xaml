<UserControl x:Class="ApocMinimal.Controls.NpcSidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="350">

    <Border Background="#0d1117" BorderBrush="#30363d" BorderThickness="1,0,0,0"
            Width="350" Visibility="Collapsed" x:Name="SidebarRoot">
        <DockPanel>
            <!-- Заголовок -->
            <Border DockPanel.Dock="Top" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SidebarTitle" Text="ИНФОРМАЦИЯ О NPC" Foreground="#60a5fa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="CloseSidebarBtn" Content="✕" Width="24" Height="24"
                            Background="#21262d" Foreground="#f87171" BorderBrush="#30363d" BorderThickness="1"
                            Click="CloseSidebar_Click" Cursor="Hand" ToolTip="Закрыть панель"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidebarContent" Margin="10"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
