<UserControl x:Class="ApocMinimal.Controls.LogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Стиль для кнопки дня -->
        <Style x:Key="DayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#60a5fa"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ArrowText" Text="▶ " Foreground="#60a5fa" FontSize="12" VerticalAlignment="Center"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a3e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки секции -->
        <Style x:Key="SectionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ArrowText" Text="▶ " Foreground="#8b949e" FontSize="10" VerticalAlignment="Center"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Setter Property="Foreground" Value="#c9d1d9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для текста лога с улучшенной читаемостью -->
        <Style x:Key="LogTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <!-- Стиль для выделенных сообщений -->
        <Style x:Key="LogTextStyleAlert" TargetType="TextBlock" BasedOn="{StaticResource LogTextStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ЖУРНАЛ" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                <Button Content="Очистить" Width="80" Margin="12,0,0,0" FontSize="11" 
                        Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d" BorderThickness="1"
                        Click="Clear_Click" Cursor="Hand"/>
                <Button Content="Свернуть всё" Width="100" Margin="6,0,0,0" FontSize="11" 
                        Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d" BorderThickness="1"
                        Click="CollapseAll_Click" Cursor="Hand"/>
                <Button Content="Развернуть всё" Width="100" Margin="6,0,0,0" FontSize="11" 
                        Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d" BorderThickness="1"
                        Click="ExpandAll_Click" Cursor="Hand"/>
                <Button Content="7 дней" Width="70" Margin="6,0,0,0" FontSize="11" 
                        Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d" BorderThickness="1"
                        Click="Filter7Days_Click" Cursor="Hand"/>
                <Button Content="Все дни" Width="70" Margin="4,0,0,0" FontSize="11" 
                        Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d" BorderThickness="1"
                        Click="ShowAll_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ScrollViewer с контентом -->
        <ScrollViewer x:Name="LogScrollViewer" 
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0d1117">
            <StackPanel x:Name="LogStackPanel" Margin="6,4"/>
        </ScrollViewer>
    </Grid>
</UserControl>