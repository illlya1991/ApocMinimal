<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ApocMinimal</AssemblyName>
    <RootNamespace>ApocMinimal</RootNamespace>
    <ApplicationIcon>Resources\earth_after_the_end.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Шаблон БД слишком большой для git, копируем только если файл есть локально -->
    <Content Include="DataBase\apoc_minimal_template.db"
             Condition="Exists('DataBase\apoc_minimal_template.db')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Resources\earth_after_the_end.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <PackageReference Include="System.Text.Json" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>

</Project>
