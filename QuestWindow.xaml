<Window x:Class="ApocMinimal.QuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квесты"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Foreground="#c9d1d9"
        FontFamily="Consolas"
        FontSize="12">

    <Window.Resources>
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#161b22"/>
            <Setter Property="AlternatingRowBackground" Value="#0d1117"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262d"/>
            <Setter Property="VerticalGridLinesBrush" Value="#21262d"/>
            <Setter Property="ColumnHeaderHeight" Value="28"/>
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1f3a5f"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#4a4a4a"/>
                    <Setter Property="Background" Value="#161b22"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="КВЕСТЫ" FontSize="15" FontWeight="Bold" Foreground="#58a6ff" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✓ Принять все готовые" Margin="0,0,8,0"
                        Background="#238636" Foreground="White" BorderBrush="#2ea043" BorderThickness="1"
                        Height="28" Padding="10,0" Cursor="Hand" Click="CollectAll_Click"/>
                <Button Grid.Column="2" Content="✕" Width="28" Height="28"
                        Background="#21262d" Foreground="#f87171"
                        BorderBrush="#30363d" BorderThickness="1"
                        Click="Close_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="10,5">
            <TextBlock x:Name="StatusText" Foreground="#8b949e" FontSize="11" Text=""/>
        </Border>

        <TabControl Background="#0d1117" BorderBrush="#30363d" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#161b22"/>
                    <Setter Property="Foreground" Value="#8b949e"/>
                    <Setter Property="BorderBrush" Value="#30363d"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#58a6ff"/>
                            <Setter Property="Background" Value="#0d1117"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Текущая">
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                <TextBlock Text="МАГАЗИН" Style="{StaticResource PanelTitle}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="TerminalFilterCombo" DockPanel.Dock="Right"
                                          Background="#21262d" Foreground="#c9d1d9" BorderBrush="#30363d"
                                          Height="22" MinWidth="80" FontSize="11"
                                          SelectionChanged="TerminalFilterCombo_SelectionChanged"/>
                            </DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Купить ×1" Style="{StaticResource ActionBtn}"
                                        Background="#1f3a1a" Foreground="#56d364" Margin="0,0,4,0"
                                        Click="BuyOneTime_Click"/>
                                <Button Content="Купить ×10" Style="{StaticResource ActionBtn}"
                                        Background="#1a2d4a" Foreground="#58a6ff"
                                        Click="BuyRepeatable_Click"/>
                                <Button Content="Купить ∞" Style="{StaticResource ActionBtn}"
                                        Background="#2d1b69" Foreground="#d2a8ff"
                                        Click="BuyEternal_Click"/>
                            </StackPanel>
                            <DataGrid x:Name="ShopGrid" Style="{StaticResource DarkDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      MouseDoubleClick="ShopGrid_DoubleClick"
                                      SelectionChanged="ShopGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Терм." Binding="{Binding MinTerminalLevel}" Width="40"/>
                                    <DataGridTextColumn Header="×1" Binding="{Binding PriceOneTime, StringFormat={}{0:F0}}" Width="50"/>
                                    <DataGridTextColumn Header="×10" Binding="{Binding PriceRepeatable, StringFormat={}{0:F0}}" Width="50"/>
                                    <DataGridTextColumn Header="∞" Binding="{Binding PriceEternal, StringFormat={}{0:F0}}" Width="50"/>
                                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="80"/>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#161b22"/>
                                        <Setter Property="Foreground" Value="#c9d1d9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1f3a5f"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="disabled">
                                                <Setter Property="Opacity" Value="0.4"/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="КУПЛЕНО" Style="{StaticResource PanelTitle}"/>
                            <Button DockPanel.Dock="Bottom" Content="Опубликовать" Style="{StaticResource ActionBtn}"
                                    Background="#1a2d4a" Foreground="#58a6ff" Margin="0,4,0,0"
                                    Click="Publish_Click"/>
                            <DataGrid x:Name="PurchasedGrid" Style="{StaticResource DarkDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      MouseDoubleClick="PurchasedGrid_DoubleClick"
                                      SelectionChanged="PurchasedGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Catalog.Title}" Width="*"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding QuestType}" Width="70"/>
                                    <DataGridTextColumn Header="Осталось" Binding="{Binding PublishLabel}" Width="60"/>
                                    <DataGridTextColumn Header="Выпол." Binding="{Binding TimesCompleted}" Width="55"/>
                                    <DataGridTextColumn Header="Награда" Binding="{Binding RewardSummary}" Width="80"/>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#161b22"/>
                                        <Setter Property="Foreground" Value="#c9d1d9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1f3a5f"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                <TextBlock Text="ОПУБЛИКОВАНО" Style="{StaticResource PanelTitle}" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DataGrid x:Name="PublishedGrid" Style="{StaticResource DarkDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      MouseDoubleClick="PublishedGrid_DoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Условия взятия" Binding="{Binding TakeCondLabelDisplay}" Width="100"/>
                                    <DataGridTextColumn Header="Выполнение" Binding="{Binding CompletionLabelDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="Награда" Binding="{Binding RewardLabelDisplay}" Width="80"/>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#161b22"/>
                                        <Setter Property="Foreground" Value="#c9d1d9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1f3a5f"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="ВЫПОЛНЯЕТСЯ" Style="{StaticResource PanelTitle}"/>
                            <DataGrid x:Name="ActiveGrid" Style="{StaticResource DarkDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      MouseDoubleClick="ActiveGrid_DoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Исполнитель" Binding="{Binding NpcNameDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="Осталось" Binding="{Binding DaysRemaining}" Width="60"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding CompletionPercent, StringFormat={}{0:F0}%}" Width="50"/>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#161b22"/>
                                        <Setter Property="Foreground" Value="#c9d1d9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1f3a5f"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsReadyDisplay}" Value="True">
                                                <Setter Property="Background" Value="#1a3a1a"/>
                                                <Setter Property="Foreground" Value="#56d364"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="История">
                <Border Background="#0d1117" Padding="8">
                    <TreeView x:Name="HistoryTree" Background="#161b22" Foreground="#c9d1d9"
                              BorderBrush="#30363d" BorderThickness="1">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="#c9d1d9"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1f3a5f"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
