<Window x:Class="ApocMinimal.QuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квесты"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Foreground="#c9d1d9"
        FontFamily="Consolas"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#60a5fa"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="QuestBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#4a4a4a"/>
                    <Setter Property="Background" Value="#161b22"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="QuestList" TargetType="ListBox">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="УПРАВЛЕНИЕ КВЕСТАМИ" FontSize="16" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Width="30" Height="30"
                        Background="#21262d" Foreground="#f87171"
                        BorderBrush="#30363d" BorderThickness="1"
                        Click="Close_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="10,6">
            <TextBlock x:Name="StatusText" Foreground="#8b949e" Text=""/>
        </Border>

        <!-- 5 columns -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1. Магазин -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="МАГАЗИН" Style="{StaticResource PanelHeader}"/>
                <TextBlock x:Name="ShopOvLabel" DockPanel.Dock="Top" Foreground="#d29922" Margin="0,0,0,4" Text=""/>
                <Button x:Name="BuyBtn" DockPanel.Dock="Bottom" Content="Купить" Style="{StaticResource QuestBtn}"
                        Background="#1f3a1a" Foreground="#56d364" Click="BuyBtn_Click"/>
                <ListBox x:Name="ShopList" Style="{StaticResource QuestList}" SelectionChanged="ShopList_SelectionChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="1" Background="#30363d" HorizontalAlignment="Center"/>

            <!-- 2. Куплено -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="КУПЛЕНО" Style="{StaticResource PanelHeader}"/>
                <Button x:Name="PublishBtn" DockPanel.Dock="Bottom" Content="Опубликовать" Style="{StaticResource QuestBtn}"
                        Background="#1a2d4a" Foreground="#58a6ff" Click="PublishBtn_Click"/>
                <ListBox x:Name="LibraryList" Style="{StaticResource QuestList}" SelectionChanged="LibraryList_SelectionChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="1" Background="#30363d" HorizontalAlignment="Center"/>

            <!-- 3. Опубликовано -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" Text="ОПУБЛИКОВАНО" Style="{StaticResource PanelHeader}"/>
                <Button x:Name="UnpublishBtn" DockPanel.Dock="Bottom" Content="Снять" Style="{StaticResource QuestBtn}"
                        Background="#3a1a1a" Foreground="#f87171" Click="UnpublishBtn_Click"/>
                <ListBox x:Name="PublishedList" Style="{StaticResource QuestList}" SelectionChanged="PublishedList_SelectionChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="5" Width="1" Background="#30363d" HorizontalAlignment="Center"/>

            <!-- 4. Выполняются -->
            <DockPanel Grid.Column="6">
                <TextBlock DockPanel.Dock="Top" Text="ВЫПОЛНЯЮТСЯ" Style="{StaticResource PanelHeader}"/>
                <TextBlock DockPanel.Dock="Bottom" Height="32" Text=""/>
                <ListBox x:Name="ActiveList" Style="{StaticResource QuestList}"/>
            </DockPanel>

            <GridSplitter Grid.Column="7" Width="1" Background="#30363d" HorizontalAlignment="Center"/>

            <!-- 5. Выполнено -->
            <DockPanel Grid.Column="8">
                <TextBlock DockPanel.Dock="Top" Text="ВЫПОЛНЕНО" Style="{StaticResource PanelHeader}"/>
                <Button x:Name="CollectAllBtn" DockPanel.Dock="Bottom" Content="Принять всё" Style="{StaticResource QuestBtn}"
                        Background="#2d1b69" Foreground="#d2a8ff" Click="CollectAllBtn_Click"/>
                <ListBox x:Name="CompletedList" Style="{StaticResource QuestList}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
